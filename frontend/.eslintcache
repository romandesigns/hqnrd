EGORY.Content>\r\n        <Button type=\"goback\">Regresar</Button>\r\n      </CATEGORY.Content>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Category;\r\n","C:\\Users\\trfm1\\Desktop\\hqnrd\\frontend\\src\\page\\guest\\Category\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\hqnrd\\frontend\\src\\components\\ui-elements\\Brand.jsx",[],{"ruleId":"151","replacedBy":"152"},{"ruleId":"153","replacedBy":"154"},{"ruleId":"151","replacedBy":"155"},{"ruleId":"153","replacedBy":"156"},{"ruleId":"157","severity":1,"message":"158","line":5,"column":10,"nodeType":"159","messageId":"160","endLine":5,"endColumn":15},{"ruleId":"151","replacedBy":"161"},{"ruleId":"153","replacedBy":"162"},{"ruleId":"157","severity":1,"message":"163","line":2,"column":17,"nodeType":"159","messageId":"160","endLine":2,"endColumn":26},{"ruleId":"157","severity":1,"message":"164","line":14,"column":20,"nodeType":"159","messageId":"160","endLine":14,"endColumn":32},"no-native-reassign",["165"],"no-negated-in-lhs",["166"],["165"],["166"],"no-unused-vars","'media' is defined but never used.","Identifier","unusedVar",["165"],["166"],"'useEffect' is defined but never used.","'setRoomSType' is assigned a value but never used.","no-global-assign","no-unsafe-negation"]