er((room) => room.category === cat);\r\n\r\n  // Checking for valid param\r\n  let categories = [\"doble-cama\", \"master\", \"doble\", \"standard\", \"basica\", \"familiar\"];\r\n  let param = categories.find((type) => (type === cat ? true : false));\r\n  const history = useHistory();\r\n  if (param === undefined) history.push(\"/\");\r\n\r\n  // Sanitizing param\r\n  const sanitizedParam = cat === \"doble-cama\" ? cat.replace(\"-\", \" \") : cat;\r\n\r\n  // useEffect(() => {\r\n  //   let result = rooms.filter((x) => x.unit === parseInt(match.params.id));\r\n  //   setRoom(result);\r\n  // }, [match.params.id]);\r\n\r\n  return (\r\n    <>\r\n      <MetaTags\r\n        ogDescription=\"Disfruta de las acomodidades que te ofrecemos; Habitaciones amplias y modernas, Smart TV, control de seguridad y mucho mas\"\r\n        ogImagePath=\"path/to/image.jpg\"\r\n        ogTitle=\"Hotel Quinto Nivel RD\"\r\n        pageDescription=\"Mas que un hotel, nosotros te proveemos la seguridad, comforte y la mejor experiencia posible; Habitaciones modernas y amplias, sistema de seguridad disponible y mucho mas.\"\r\n        pageTitle={`Habitaciones ${sanitizedParam}`}\r\n      />\r\n\r\n      <Header img_src={`/img/category/${cat}.jpg`}>\r\n        <CATEGORY.HeaderWrapper>{<Brand heading=\"h1\" />}</CATEGORY.HeaderWrapper>\r\n      </Header>\r\n\r\n      <CATEGORY.Content>\r\n        <CATEGORY.Description>\r\n          <h2>{`Habitaciones ${sanitizedParam}`}</h2>\r\n          <p>\r\n            Lorem ipsum dolor sit amet consectetur adipisicing elit. Non tempora sunt magnam a optio aspernatur nobis exercitationem perspiciatis? Soluta quod\r\n            officia mollitia. Esse modi velit aliquam illo sed, reprehenderit enim.\r\n          </p>\r\n          <Button type=\"goback\">Regresar</Button>\r\n        </CATEGORY.Description>\r\n\r\n        <CATEGORY.Rooms>\r\n          {matchedRooms.map((room, index) => (\r\n            <Card\r\n              key={index}\r\n              type=\"room\"\r\n              price={room.price}\r\n              bg=\"light\"\r\n              category={sanitizedParam}\r\n              img_src={room.img.hero}\r\n              path_to={`${url}/habitacion/${room.unit}`}\r\n              unit={room.unit}\r\n            />\r\n          ))}\r\n        </CATEGORY.Rooms>\r\n      </CATEGORY.Content>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default Category;\r\n","C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Footer\\index.jsx",[],["164","165"],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\page\\NotFound\\style.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\utils\\apps.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\page\\guest\\Home\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\page\\guest\\Category\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Footer\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\ui-elements\\Brand.jsx",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\page\\guest\\Home\\index.jsx",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\ui-elements\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Features\\styles.js",[],["166","167"],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Features\\index.jsx",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\ui-elements\\Card.jsx",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Categories\\CategoriesTemplate.jsx",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\components\\layout\\Categories\\styles.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\App.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\utils\\global.js",[],"C:\\Users\\trfm1\\Desktop\\dev\\hqnrd\\frontend\\src\\page\\guest\\RoomDetails\\index.jsx",[],"C:\\Users\\t